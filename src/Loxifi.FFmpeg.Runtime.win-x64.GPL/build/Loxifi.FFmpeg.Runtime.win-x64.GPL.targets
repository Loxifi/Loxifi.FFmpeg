<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyFFmpegWinX64GPLNatives" AfterTargets="Build" Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <ItemGroup>
      <_FFmpegWinX64GPLFiles Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_FFmpegWinX64GPLFiles)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CopyFFmpegWinX64GPLNativesPublish" AfterTargets="Publish" Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <ItemGroup>
      <_FFmpegWinX64GPLFiles Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_FFmpegWinX64GPLFiles)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" />
  </Target>
</Project>
