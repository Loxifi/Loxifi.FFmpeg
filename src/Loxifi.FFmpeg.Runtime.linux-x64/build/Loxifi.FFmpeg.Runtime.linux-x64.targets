<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyFFmpegLinuxX64Natives" AfterTargets="Build" Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <ItemGroup>
      <_FFmpegLinuxX64Files Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\*" />
    </ItemGroup>
    <MakeDir Directories="$(OutDir)runtimes/linux-x64/native" />
    <Copy SourceFiles="@(_FFmpegLinuxX64Files)" DestinationFolder="$(OutDir)runtimes/linux-x64/native" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CopyFFmpegLinuxX64NativesPublish" AfterTargets="Publish" Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <ItemGroup>
      <_FFmpegLinuxX64Files Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\*" />
    </ItemGroup>
    <MakeDir Directories="$(PublishDir)runtimes/linux-x64/native" />
    <Copy SourceFiles="@(_FFmpegLinuxX64Files)" DestinationFolder="$(PublishDir)runtimes/linux-x64/native" SkipUnchangedFiles="true" />
  </Target>
</Project>
