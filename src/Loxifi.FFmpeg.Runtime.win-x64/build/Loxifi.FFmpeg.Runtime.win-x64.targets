<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyFFmpegWinX64Natives" AfterTargets="Build" Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <ItemGroup>
      <_FFmpegWinX64Files Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_FFmpegWinX64Files)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CopyFFmpegWinX64NativesPublish" AfterTargets="Publish" Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <ItemGroup>
      <_FFmpegWinX64Files Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_FFmpegWinX64Files)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" />
  </Target>
</Project>
