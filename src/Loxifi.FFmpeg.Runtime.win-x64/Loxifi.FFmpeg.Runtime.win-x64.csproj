<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageId>Loxifi.FFmpeg.Runtime.win-x64</PackageId>
    <Description>FFmpeg 7.1 LGPL native binaries for win-x64. Install alongside Loxifi.FFmpeg.</Description>
    <PackageLicenseExpression>LGPL-3.0-or-later</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="runtimes\win-x64\native\**" PackagePath="runtimes\win-x64\native" CopyToOutputDirectory="PreserveNewest" Link="runtimes\win-x64\native\%(Filename)%(Extension)" />
    <None Include="..\RUNTIME_README_LGPL.md" Pack="true" PackagePath="README.md" />
  </ItemGroup>


  <ItemGroup>
    <Content Include="build\\**" PackagePath="build" />
    <Content Include="buildTransitive\\**" PackagePath="buildTransitive" />
  </ItemGroup>

</Project>
